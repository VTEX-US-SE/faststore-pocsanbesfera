[
  {
    "name": "CategoryCards",
    "schema": {
      "title": "Category Cards",
      "description": "Flex layout cards with image and text of categories",
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": {
          "title": "Title",
          "type": "string"
        },
        "images": {
          "title": "Cards",
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "title": "Card",
            "type": "object",
            "required": [
              "imageTitle",
              "imageAlt",
              "link",
              "imageSrcDesktop",
              "imageSrcMobile"
            ],
            "properties": {
              "imageTitle": {
                "type": "string",
                "title": "Image Title"
              },
              "imageAlt": {
                "type": "string",
                "title": "Image Alt"
              },
              "link": {
                "type": "string",
                "title": "Link"
              },
              "imageSrcDesktop": {
                "type": "string",
                "title": "Desktop Image",
                "widget": {
                  "ui:widget": "media-gallery"
                }
              },
              "imageSrcMobile": {
                "type": "string",
                "title": "Mobile Image",
                "widget": {
                  "ui:widget": "media-gallery"
                }
              }
            }
          }
        }
      }
    }
  },
